# Backend API URL (set this to your deployed backend URL)
# For local development, leave empty to use http://localhost:3001
VITE_API_URL=

# Production: Set to your Railway/Render backend URL
# VITE_API_URL=https://your-backend.railway.app

# Supabase Configuration (for admin dashboard only)
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_SUPABASE_URL=https://your-project.supabase.co
